<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network permissions for API calls -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Camera permission for barcode scanning -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Location permissions for GPS and WiFi scanning -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- WiFi permissions for indoor location tracking -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- Foreground Service permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Package visibility declarations for Android 11+ (API 30+) -->
    <!-- Required to use resolveActivity() for implicit intents -->
    <queries>
        <!-- For phone dial intent -->
        <intent>
            <action android:name="android.intent.action.DIAL" />
            <data android:scheme="tel" />
        </intent>

        <!-- For sharing content -->
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="text/plain" />
        </intent>

        <!-- For sending emails -->
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="mailto" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HuyBrancardage">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.HuyBrancardage">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            HelpActivity - Activité d'aide et d'informations

            Cette activité est lancée via un Intent EXPLICITE depuis l'écran d'accueil.
            Elle n'a pas de filtre d'intent car elle n'est accessible que depuis notre application.

            android:exported="false" : Non accessible depuis d'autres applications
            android:parentActivityName : Permet la navigation "Up" vers MainActivity
        -->
        <activity
            android:name=".HelpActivity"
            android:exported="false"
            android:label="@string/help_title"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.HuyBrancardage" />

        <!-- FileProvider for sharing camera images -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.huybrancardage.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!--
            TrackingService - Service de suivi en temps réel du brancardier

            Ce service foreground :
            - Scanne périodiquement les bornes WiFi pour la géolocalisation indoor
            - Affiche une notification persistante avec la position actuelle
            - Envoie les mises à jour de position au serveur

            android:foregroundServiceType="location" : Requis depuis Android 10 pour
            accéder à la localisation depuis un foreground service.
        -->
        <service
            android:name=".service.TrackingService"
            android:foregroundServiceType="location"
            android:exported="false" />
    </application>

</manifest>
